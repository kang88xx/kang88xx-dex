# Reown (WalletConnect) project ID — create at https://dashboard.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Which BNB chain to run on: "testnet" (chainId 97, default) or "mainnet" (56)
NEXT_PUBLIC_CHAIN_ENV=testnet
# Your deployed test USDT address on BSC testnet (see TESTNET.md). Testnet only.
NEXT_PUBLIC_TUSDT_ADDRESS=
# Optional overrides if PancakeSwap testnet router/WBNB ever change:
# NEXT_PUBLIC_PANCAKE_ROUTER=
# NEXT_PUBLIC_WBNB=

# Admin auth (server-only — never exposed to the client)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Testnet USDT bridge: BSC Testnet ↔ opBNB Testnet (npm run deploy:bridge
# prints all four). Leave empty to keep /bridge in "coming soon" mode.
NEXT_PUBLIC_BRIDGE_TESTNET_BSC=
NEXT_PUBLIC_BRIDGE_TESTNET_OPBNB=
NEXT_PUBLIC_TUSDT_OPBNB_ADDRESS=
# Relayer key (server-only) — signs release() on the destination chain.
# Testnet-only key; on testnet the deployer key is fine.
BRIDGE_RELAYER_PRIVATE_KEY=
