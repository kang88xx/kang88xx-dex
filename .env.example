# Reown (WalletConnect) project ID — create at https://dashboard.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=

# ---- Xphere Mainnet (chainId 20250217) ----
# Optional RPC/explorer overrides (defaults: xp-mainnet.rpc.xplorium.xyz / xp.tamsa.io)
# NEXT_PUBLIC_XPHERE_RPC=
# NEXT_PUBLIC_XPHERE_EXPLORER=

# Our Uniswap-V2-fork DEX contracts — `cd dex-contracts && npm run deploy`
# prints all three. Swaps/pools stay disabled while these are empty.
NEXT_PUBLIC_DEX_ROUTER=
NEXT_PUBLIC_DEX_FACTORY=
NEXT_PUBLIC_WXP=

# Game / airdrop contracts on Xphere (empty = feature disabled until deployed)
NEXT_PUBLIC_LMS_CONTRACT=
NEXT_PUBLIC_AIRDROP_CONTRACT=

# Admin auth (server-only — never exposed to the client)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Durable analytics (visitors / wallet connections / 24h volume). Provision an
# Upstash Redis DB in the Vercel dashboard (Storage → Upstash for Redis) — it
# auto-injects KV_REST_API_* (those names work too). Without them, analytics
# fall back to per-instance memory and reset on every redeploy/cold start.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
