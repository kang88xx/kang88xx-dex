# Copy to .env.deploy (gitignored) and fill in. TESTNET ONLY.
# Used by `npm run deploy:token` to deploy a TestToken to BSC testnet.

# A throwaway TESTNET private key that holds ONLY test BNB.
# NEVER use a key with real funds / a mainnet key here.
DEPLOYER_PRIVATE_KEY=

# Token to deploy (change these to mint a different token / meme coin)
TOKEN_NAME=Test Tether
TOKEN_SYMBOL=USDT
TOKEN_SUPPLY=1000000

# Optional: override the testnet RPC
# BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545
