{
  "name": "dex-contracts",
  "version": "1.0.0",
  "private": true,
  "description": "Uniswap V2 (PancakeSwap-equivalent) DEX for the Xphere chain: WXP + Factory + Router02.",
  "scripts": {
    "compile": "hardhat compile",
    "hash": "hardhat run scripts/compute-init-hash.ts",
    "deploy": "hardhat run scripts/deploy.ts --network xphere",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhat",
    "seed": "hardhat run scripts/seed-liquidity.ts --network xphere"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.10"
  }
}
